{
  "name": "di-benchmarks",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.3.0",
  "description": "Comparative DI container benchmarks.",
  "scripts": {
    "bench": "cross-env NODE_OPTIONS=\"--no-warnings\" vitest bench --run",
    "bench:watch": "cross-env NODE_OPTIONS=\"--no-warnings\" vitest bench",
    "precondition": "vitest run src/precondition",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "inversify": "^8.1.0",
    "awilix": "^13.0.3",
    "tsyringe": "^4.10.0",
    "typedi": "^0.10.0",
    "typed-inject": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "vitest": "^4.1.5",
    "unplugin-swc": "^1.5.9",
    "@swc/core": "^1.15.33",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
