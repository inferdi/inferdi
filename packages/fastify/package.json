{
  "name": "@inferdi/fastify",
  "version": "4.0.8",
  "description": "Fastify request-scope adapter for InferDI.",
  "keywords": [
    "typescript",
    "dependency-injection",
    "di",
    "ioc",
    "inferdi",
    "fastify",
    "fastify-plugin",
    "request-scope"
  ],
  "author": {
    "name": "Viacheslav Kabanov",
    "email": "vkabanov@inferdi.com",
    "url": "https://github.com/maxrendel"
  },
  "license": "MIT",
  "homepage": "https://github.com/inferdi/inferdi/tree/main/packages/fastify#readme",
  "bugs": {
    "url": "https://github.com/inferdi/inferdi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferdi/inferdi.git",
    "directory": "packages/fastify"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@inferdi/inferdi": "^4.0.0",
    "fastify": "^5.0.0"
  },
  "dependencies": {
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@inferdi/inferdi": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "fastify": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest --typecheck.enabled --run",
    "prepublishOnly": "pnpm run clean && pnpm run typecheck && pnpm run build"
  }
}
