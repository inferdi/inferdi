{
  "name": "@inferdi/inferdi",
  "version": "1.0.2",
  "description": "Zero-dependency, decorator-free, strictly typed DI container for TypeScript. Features scopes, lazy injection, lifetime guards, and explicit async teardown.",
  "keywords": [
    "typescript",
    "dependency-injection",
    "di",
    "ioc",
    "container",
    "inversion-of-control",
    "scoped",
    "disposable",
    "no-decorators",
    "zero-dependency",
    "fluent-api"
  ],
  "author": {
    "name": "Viacheslav Kabanov",
    "email": "vkabanov@inferdi.com",
    "url": "https://github.com/maxrendel"
  },
  "license": "MIT",
  "homepage": "https://github.com/inferdi/inferdi#readme",
  "bugs": {
    "url": "https://github.com/inferdi/inferdi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferdi/inferdi.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
