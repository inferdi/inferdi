{
  "name": "inferdi-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm -r --filter @inferdi/* build",
    "clean": "pnpm -r --filter @inferdi/* clean",
    "typecheck": "pnpm -r --filter @inferdi/* typecheck",
    "test": "pnpm -r --filter @inferdi/* test",
    "test:watch": "pnpm -r --parallel --filter @inferdi/* test:watch",
    "test:coverage": "pnpm -r --filter @inferdi/* test:coverage",
    "test:types": "pnpm -r --filter @inferdi/* test:types",
    "bench": "pnpm --filter @inferdi/inferdi bench",
    "benchmarks:install": "pnpm --dir benchmarks install",
    "benchmarks:precondition": "pnpm --dir benchmarks run precondition",
    "benchmarks:bench": "pnpm --dir benchmarks run bench"
  }
}
